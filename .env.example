# Copy to .env and fill in. Never commit .env (gitignored).

# Groq - required for POST /api/chat
GROQ_API_KEY=

# Optional model id (default: llama3-70b-8192)
# GROQ_MODEL=llama3-70b-8192

# SQLite DB path (default: project root o2c_context.db)
# O2C_DB_PATH=

# Raw JSONL root for NetworkX ingest (default: data/raw)
# O2C_RAW_ROOT=
