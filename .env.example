# Copy to .env and fill in. Never commit .env (gitignored).

# Google Gemini (Antigravity) — required for POST /api/chat
GEMINI_API_KEY=
# Optional fallback name used by some Google samples
# GOOGLE_API_KEY=

# Optional model id (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# SQLite DB path (default: project root o2c_context.db)
# O2C_DB_PATH=

# Raw JSONL root for NetworkX ingest (default: data/raw)
# O2C_RAW_ROOT=
